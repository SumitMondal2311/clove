{
    "$schema": "https://turborepo.com/schema.json",
    "tasks": {
        "dev": {
            "dependsOn": ["^dev"],
            "outputs": [],
            "cache": false,
            "persistent": true
        },
        "build": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "web#build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "!.next/cache/**"]
        },
        "api#build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "@clove/env#build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "@clove/database#build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "generated/prisma/**"]
        },
        "db:generate": {
            "cache": false
        },
        "db:migrate": {
            "cache": false,
            "persistent": true
        },
        "db:deploy": {
            "cache": false
        },
        "start": {
            "dependsOn": ["^start"],
            "outputs": [],
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["^lint"],
            "outputs": []
        },
        "clean": {
            "dependsOn": ["^clean"],
            "outputs": []
        },
        "check-types": {
            "dependsOn": ["^check-types"],
            "outputs": []
        }
    }
}
