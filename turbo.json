{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"]
        },
        "dashboard#build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "!.next/cache/**"]
        },
        "server#build": {
            "dependsOn": ["^build"],
            "env": ["NODE_ENV", "PORT", "API_ORIGIN", "WEB_ORIGIN"],
            "outputs": ["dist/**"]
        },
        "@clove/db#build": {
            "dependsOn": ["^build"],
            "env": ["NODE_ENV", "DATABASE_URL"],
            "outputs": ["dist/**"]
        },
        "db:deploy": {
            "cache": false
        },
        "db:generate": {
            "cache": false
        },
        "db:migrate": {
            "cache": false,
            "persistent": true
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "clean": {
            "dependsOn": ["^clean"],
            "cache": false
        },
        "dev": {
            "dependsOn": ["^dev"],
            "cache": false
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "start": {
            "dependsOn": ["^start"],
            "cache": false
        }
    }
}
