{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"]
        },
        "web#build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "!.next/cache/**"]
        },
        "api#build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"],
            "env": ["NODE_ENV", "PORT", "DATABASE_URL", "WEB_ORIGIN", "API_ORIGIN", "JWT_SECRET"]
        },
        "db:generate": {
            "cache": false,
            "outputs": ["generated/**"]
        },
        "db:deploy": {
            "cache": false,
            "persistent": true
        },
        "db:migrate": {
            "cache": false
        },
        "@clove/database#build": {
            "dependsOn": ["db:generate", "^build"],
            "outputs": ["dist/**"]
        },
        "@clove/logger#build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "clean": {
            "dependsOn": ["^clean"],
            "cache": false
        },
        "dev": {
            "dependsOn": ["^dev"],
            "cache": false,
            "persistent": true
        },
        "start": {
            "dependsOn": ["^start"],
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["db:generate", "^check-types"]
        },
        "test:unit": {
            "dependsOn": ["^test:unit"]
        },
        "test:integration": {
            "dependsOn": ["^test:integration"]
        }
    }
}
