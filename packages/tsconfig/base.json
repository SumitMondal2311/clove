{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "moduleResolution": "bundler",
        "target": "es2024",
        "allowJs": false,
        "esModuleInterop": true,
        "incremental": false,
        "module": "esnext",
        "isolatedModules": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true
    }
}
