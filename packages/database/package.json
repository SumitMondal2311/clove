{
    "name": "@clove/database",
    "private": true,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "check-types": "tsc --noEmit",
        "clean": "rm -rf .turbo dist generated",
        "db:deploy": "dotenv -e .env.production prisma migrate deploy",
        "db:format": "prisma format",
        "db:migrate": "dotenv -e .env.development prisma migrate dev --skip-generate",
        "db:push": "dotenv -e .env.development prisma db push && dotenv -e .env.test prisma db push",
        "db:studio": "dotenv -e .env.development prisma studio",
        "generate": "dotenv -e .env.development prisma generate && dotenv -e .env.test prisma generate",
        "lint": "eslint .",
        "pre-build": "pnpm clean"
    },
    "dependencies": {
        "@prisma/client": "6.11.0"
    },
    "devDependencies": {
        "@clove/eslint": "workspace:^",
        "@clove/tsconfig": "workspace:^",
        "dotenv-cli": "^8.0.0",
        "prisma": "^6.11.0"
    }
}
