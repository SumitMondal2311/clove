generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  email     String   @unique
  password  String
  verfied   Boolean  @default(false)

  sessions Session[]

  @@map("users")
}

model Session {
  id           Int       @id @default(autoincrement())
  createdAt    DateTime  @default(now())
  userAgent    String?
  ipAddress    String?
  refreshToken String
  revoked      Boolean   @default(false)
  revokedAt    DateTime?
  expiresAt    DateTime

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  @@unique([userId, refreshToken])
  @@map("sessions")
}
