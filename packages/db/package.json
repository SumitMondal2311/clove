{
    "name": "@clove/db",
    "private": true,
    "type": "module",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./src/index.ts"
            }
        }
    },
    "scripts": {
        "build": "tsc",
        "check-types": "tsc --noEmit",
        "clean": "rm -rf .turbo dist",
        "db:deploy": "dotenv -e .env.production prisma migrate deploy",
        "db:generate": "prisma generate",
        "db:migrate": "dotenv -e .env.development prisma migrate dev --skip-generate",
        "db:push": "dotenv -e .env.development prisma db push",
        "db:studio": "dotenv -e .env.development prisma studio",
        "lint": "eslint ."
    },
    "dependencies": {
        "@prisma/client": "6.11.0"
    },
    "devDependencies": {
        "@clove/eslint": "workspace:^",
        "@clove/tsconfig": "workspace:^",
        "dotenv-cli": "^8.0.0",
        "prisma": "^6.11.0"
    }
}
