{
    "name": "clove-monorepo",
    "private": true,
    "scripts": {
        "check-types": "turbo check-types",
        "format": "prettier --write .",
        "prepare": "husky",
        "build": "turbo build",
        "build:packages": "turbo build -F @clove/**",
        "dev": "turbo dev",
        "start": "turbo start",
        "lint": "turbo lint",
        "lint-staged": "lint-staged",
        "clean": "turbo clean"
    },
    "lint-staged": {
        "*.{js,ts,jsx,tsx,json}": "prettier --write"
    },
    "devDependencies": {
        "@types/node": "^20.19.4",
        "eslint": "^9.30.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.2",
        "prettier": "^3.6.2",
        "tsup": "^8.5.0",
        "turbo": "^2.5.4",
        "typescript": "^5.8.3"
    },
    "packageManager": "pnpm@9.0.0",
    "engines": {
        "node": ">=18"
    }
}
