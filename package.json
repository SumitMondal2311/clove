{
    "name": "clove-monorepo",
    "private": true,
    "scripts": {
        "check-types": "turbo run check-types",
        "clean": "turbo run clean",
        "build": "turbo run build",
        "build:packages": "pnpm build -F @clove/**",
        "dev": "turbo run dev",
