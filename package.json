        "lint": "turbo run lint",
        "prepare": "husky",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "eslint": "^9.29.0",
        "husky": "^9.1.7",
        "prettier": "^3.6.2",
        "turbo": "^2.5.4",
        "typescript": "^5.8.3"
    },
    "packageManager": "pnpm@9.0.0",
    "engines": {
        "node": ">=18"
    }
