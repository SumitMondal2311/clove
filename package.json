{
    "name": "clove-turborepo",
    "private": true,
    "scripts": {
        "build": "turbo build",
        "check-types": "turbo check-types",
        "clean": "turbo clean",
        "dev": "turbo dev",
        "format": "prettier --write \"**/*.{js,mjs,ts,jsx,tsx,json}\"",
        "lint": "turbo lint",
        "prepare": "husky",
        "start": "turbo start"
    },
    "lint-staged": {
        "**/*.{js,mjs,ts,jsx,tsx,json}": "prettier --write"
    },
    "dependencies": {
        "dotenv": "^17.2.1",
        "zod": "^4.0.14"
    },
    "devDependencies": {
        "cross-env": "^10.0.0",
        "eslint": "^9.32.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.2",
        "prettier": "^3.6.2",
        "prettier-plugin-packagejson": "^2.5.19",
        "turbo": "^2.5.5",
        "typescript": "^5.8.3"
    },
    "packageManager": "pnpm@9.0.0",
    "engines": {
        "node": ">=18"
    }
