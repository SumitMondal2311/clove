{
    "name": "server",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "cross-env NODE_ENV=production tsup && pnpm copy-assets",
        "check-types": "tsc --noEmit",
        "clean": "rm -rf .turbo dist",
        "copy-assets": "node ./src/scripts/copy-assets.ts",
        "dev": "cross-env NODE_ENV=development tsx watch ./src/index.ts",
        "lint": "eslint .",
        "start": "cross-env NODE_ENV=production node ./dist/index.js"
    },
    "dependencies": {
        "bcryptjs": "^3.0.2",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "express": "^5.1.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0"
    },
    "devDependencies": {
        "@clove/db": "workspace:^",
        "@clove/eslint": "workspace:^",
        "@clove/tsconfig": "workspace:^",
        "@types/cookie-parser": "^1.4.9",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "ioredis": "^5.6.1",
        "tsx": "^4.20.3"
    }
}
